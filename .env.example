# ─── BINGX ────────────────────────────────────────────────────────────────────
# Obtén en BingX → Perfil → Gestión de API
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET=tu_secret_key_aqui

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
# TELEGRAM_TOKEN: habla con @BotFather en Telegram → /newbot
# TELEGRAM_CHAT_ID: habla con @userinfobot en Telegram
TELEGRAM_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
# Obtén en console.anthropic.com → API Keys
ANTHROPIC_API_KEY=tu_api_key_aqui

# ─── BOT CONFIG ───────────────────────────────────────────────────────────────
CAPITAL_TOTAL=100
APALANCAMIENTO=10
